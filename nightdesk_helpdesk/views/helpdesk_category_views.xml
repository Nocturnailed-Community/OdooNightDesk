<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_helpdesk_category_list" model="ir.ui.view">
        <field name="name">helpdesk.category.list</field>
        <field name="model">helpdesk.category</field>
        <field name="arch" type="xml">
            <list string="Categories" editable="bottom">
                <field name="name"/>
                <field name="parent_id"/>
            </list>
        </field>
    </record>

    <record id="view_helpdesk_category_form" model="ir.ui.view">
        <field name="name">helpdesk.category.form</field>
        <field name="model">helpdesk.category</field>
        <field name="arch" type="xml">
            <form string="Category">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="parent_id"/>
                        <field name="description"/>
                    </group>
                    <field name="child_ids" readonly="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_helpdesk_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">helpdesk.category</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
